# Дерекқор — Postgres қосылым сілтемесі.
#  Railway-де Postgres сервисін қосып, оның DATABASE_URL-ын осы қосымшаға беріңіз.
#  Мысал: postgresql://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL="postgresql://user:password@localhost:5432/school?schema=public"

# Бастапқы admin аккаунты (тек seed кезінде қолданылады)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"
ADMIN_NAME="Жүйе әкімшісі"
